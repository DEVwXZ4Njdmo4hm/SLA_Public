{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "secrets.schema.json",
  "title": "Secrets Configuration",
  "description": "Validates secrets.toml — credentials written to credentials.db at deployment.",
  "type": "object",
  "required": [
    "elasticsearch"
  ],
  "additionalProperties": false,
  "$defs": {
    "secret_entry": {
      "type": "object",
      "required": [
        "value"
      ],
      "additionalProperties": false,
      "properties": {
        "value": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "properties": {
    "elasticsearch": {
      "type": "object",
      "required": [
        "username",
        "password"
      ],
      "additionalProperties": false,
      "properties": {
        "username": {
          "$ref": "#/$defs/secret_entry"
        },
        "password": {
          "$ref": "#/$defs/secret_entry"
        }
      }
    },
    "log_output": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "username": {
          "$ref": "#/$defs/secret_entry"
        },
        "password": {
          "$ref": "#/$defs/secret_entry"
        }
      }
    },
    "auth": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "jwt_secret": {
          "$ref": "#/$defs/secret_entry"
        },
        "owner": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "username": {
              "type": "string",
              "minLength": 1
            },
            "password": {
              "type": "string",
              "minLength": 8
            },
            "email": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "git": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "token": {
          "$ref": "#/$defs/secret_entry"
        }
      }
    },
    "llm": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "api_key": {
          "$ref": "#/$defs/secret_entry"
        }
      }
    },
    "mail": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "client_id": {
          "$ref": "#/$defs/secret_entry"
        },
        "client_secret": {
          "$ref": "#/$defs/secret_entry"
        }
      }
    }
  }
}
