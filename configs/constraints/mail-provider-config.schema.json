{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "mail-provider-config.schema.json",
  "title": "Mail Provider Configuration",
  "description": "Validates mail provider config files (e.g., outlook.toml, gmail.toml).",
  "type": "object",
  "required": [
    "mail_provider"
  ],
  "properties": {
    "mail_provider": {
      "type": "object",
      "minProperties": 1,
      "maxProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": [
          "provider",
          "smtp"
        ],
        "properties": {
          "provider": {
            "type": "string",
            "minLength": 1
          },
          "smtp": {
            "type": "object",
            "required": [
              "auth_methods",
              "host",
              "port"
            ],
            "properties": {
              "auth_methods": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "password",
                    "OAuth2"
                  ]
                },
                "minItems": 1
              },
              "host": {
                "type": "string",
                "minLength": 1
              },
              "port": {
                "type": "integer",
                "minimum": 1,
                "maximum": 65535
              }
            }
          },
          "oauth2": {
            "type": "object",
            "required": [
              "authority",
              "scopes"
            ],
            "properties": {
              "authority": {
                "type": "string",
                "minLength": 1
              },
              "scopes": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "minItems": 1
              }
            }
          }
        }
      }
    }
  }
}
